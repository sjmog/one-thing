{
  "name": "one-thing",
  "version": "1.4.9",
  "description": "One Thing - Daily goal planning app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --win --linux",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "release": "export $(cat .env | xargs) && electron-builder --mac --publish always"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "dotenv": "^17.4.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.onething.app",
    "productName": "One Thing",
    "files": [
      "main.js",
      "preload.js",
      "icon.png",
      "icon-dark.png"
    ],
    "extraResources": [
      {
        "from": "../index.html",
        "to": "index.html"
      },
      {
        "from": "../favicon.ico",
        "to": "favicon.ico"
      },
      {
        "from": "../favicon-16.png",
        "to": "favicon-16.png"
      },
      {
        "from": "../favicon-32.png",
        "to": "favicon-32.png"
      },
      {
        "from": "../FunnelSans.woff2",
        "to": "FunnelSans.woff2"
      },
      {
        "from": "icon.png",
        "to": "icon.png"
      },
      {
        "from": "icon-dark.png",
        "to": "icon-dark.png"
      }
    ],
    "mac": {
      "icon": "icon.png",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist"
    },
    "publish": {
      "provider": "github",
      "owner": "sjmog",
      "repo": "one-thing",
      "releaseType": "release"
    },
    "win": {
      "icon": "icon.png",
      "target": "nsis"
    },
    "linux": {
      "icon": "icon.png",
      "target": "AppImage"
    },
    "directories": {
      "output": "dist"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}

{
  "name": "one-thing",
  "version": "1.3.1",
  "description": "One Thing - Daily goal planning app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --win --linux",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.onething.app",
    "productName": "One Thing",
    "files": [
      "main.js",
      "preload.js",
      "icon.png",
      "../index.html",
      "../favicon.ico",
      "../favicon-16.png",
      "../favicon-32.png",
      "../FunnelSans.woff2"
    ],
    "mac": {
      "icon": "icon.png",
      "target": "dmg"
    },
    "win": {
      "icon": "icon.png",
      "target": "nsis"
    },
    "linux": {
      "icon": "icon.png",
      "target": "AppImage"
    },
    "directories": {
      "output": "dist"
    }
  }
}
